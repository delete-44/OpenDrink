{
  "expo": {
    "name": "OpenDrink",
    "slug": "OpenDrink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "opendrink",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#540D6E",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.delete44.OpenDrink"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/deck.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#540D6E",
          "dark": {
            "backgroundColor": "#540D6E"
          }
        }
      ],
      "expo-font",
      "expo-image",
      [
        "expo-sqlite",
        {
          "useSQLCipher": true,
          "ios": {
            "customBuildFlags": [
              "-DSQLITE_ENABLE_DBSTAT_VTAB=1 -DSQLITE_ENABLE_SNAPSHOT=1"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ebf19dd1-4d91-4620-9a1c-a0d0e03a529b"
      }
    }
  }
}
